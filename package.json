{
  "name": "rizzz-media",
  "version": "1.0.0",
  "description": "Full-stack Marketing Agency Website",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "marketing",
    "agency",
    "landing-page",
    "fullstack",
    "react",
    "express"
  ],
  "author": "Akash Yadav",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
